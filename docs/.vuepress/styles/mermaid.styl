.theme-vdoing-content .mermaid-chart
  margin 1.2rem 0
  text-align center
  overflow-x auto

.theme-vdoing-content .mermaid-chart .mermaid-source
  display none

.theme-vdoing-content .mermaid-chart.is-rendered svg
  max-width 100%
  height auto
  display block
  margin 0 auto

.theme-vdoing-content .mermaid-chart.is-error .mermaid-error
  color #c62828
  background #ffebee
  padding 12px 16px
  border-radius 4px
  font-size 14px
  text-align left
  white-space pre-wrap
